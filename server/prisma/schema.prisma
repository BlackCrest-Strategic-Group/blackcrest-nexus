generator client { provider = "prisma-client-js" }

datasource db { provider = "postgresql" url = env("DATABASE_URL") }

model User {
  id          String   @id @default(cuid())
  clerkId     String?  @unique
  name        String
  role        String
  facility    String
  permissions String[]
  alerts      OperationalAlert[]
}

model Supplier {
  id               String   @id @default(cuid())
  supplierName     String
  category         String
  region           String
  leadTimeAverage  Int
  deliveryScore    Float
  riskScore        Float
  escalationLevel  String
  status           String
  purchaseOrders   PurchaseOrder[]
  rfqs             RFQ[]
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNumber      String   @unique
  supplierId    String
  material      String
  quantity      Int
  dueDate       DateTime
  status        String
  cost          Float
  riskFlag      Boolean  @default(false)
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  jobAssignments JobPO[]
  alerts        OperationalAlert[]
}

model ManufacturingJob {
  id                String   @id @default(cuid())
  jobNumber          String   @unique
  productionPhase    String
  materialStatus     String
  blockedReason      String?
  completionPercent  Int
  purchaseOrders     JobPO[]
  alerts             OperationalAlert[]
}

model JobPO {
  jobId String
  poId  String
  job   ManufacturingJob @relation(fields:[jobId], references:[id])
  po    PurchaseOrder @relation(fields:[poId], references:[id])
  @@id([jobId, poId])
}

model RFQ {
  id            String   @id @default(cuid())
  rfqNumber     String   @unique
  item          String
  requestedQty  Int
  dueDate       DateTime
  supplierId    String
  estimatedCost Float
  status        String
  supplier      Supplier @relation(fields:[supplierId], references:[id])
}

model OperationalAlert {
  id                String   @id @default(cuid())
  severity          String
  alertType         String
  relatedSupplierId String?
  relatedJobId      String?
  relatedPoId       String?
  aiSummary         String
  recommendedAction String
  createdAt         DateTime @default(now())
  assignedUserId    String?
  user              User? @relation(fields:[assignedUserId], references:[id])
  supplier          Supplier? @relation(fields:[relatedSupplierId], references:[id])
  job               ManufacturingJob? @relation(fields:[relatedJobId], references:[id])
  po                PurchaseOrder? @relation(fields:[relatedPoId], references:[id])
}
