{
  "name": "blackcrest-opportunity-funding-intelligence-engine",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "prestart": "npm run check:syntax",
    "start": "node server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPatterns=tests/",
    "build:frontend": "cd frontend && npm install --include=dev && npm run build",
    "dev:full": "concurrently \"npm run dev\" \"cd frontend && npm run dev\"",
    "check:syntax": "bash -lc 'node --check server.js && rg --files backend routes -g \"*.js\" | xargs -n1 node --check'",
    "verify": "npm run check:syntax && npm test -- --runInBand",
    "migrate:tenant": "node server/scripts/migrateTenantScoping.js",
    "sentinel:report": "node qa/utils/generateSummary.js",
    "sentinel:summary": "bash -lc 'node qa/utils/generateSummary.js && cat qa/reports/summaries/demo-readiness.md'"
  },
  "keywords": [
    "opportunity-intelligence",
    "funding-intelligence",
    "contract-analysis",
    "lender-matching",
    "business-financing",
    "document-analysis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dd-trace": "^5.89.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.15.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "openai": "^6.33.0",
    "pdf-parse": "1.1.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "stripe": "^22.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14"
  },
  "jest": {
    "transform": {}
  }
}
