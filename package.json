{
  "name": "blackcrest-nexus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "install-all": "npm install && npm install --prefix client && npm install --prefix server",
    "dev": "npm run dev --prefix server",
    "build": "npm run build --prefix client && npm run prisma:generate --prefix server",
    "build:frontend": "cd client && npm install && npm run build",
    "start": "node server/server.js",
    "check:syntax": "node --check server/server.js",
    "validate": "npm run check:syntax && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^5.22.0",
    "xlsx": "^0.18.5",
    "mongoose": "^8.14.1",
    "stripe": "^18.4.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^8.1.0",
    "express-rate-limit": "^7.5.0",
    "compression": "^1.8.1",
    "swagger-ui-express": "^5.0.1"
  }
}