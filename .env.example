# GovCon AI Scanner – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to source control.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (default: localhost dev ports)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/govcon?retryWrites=true&w=majority

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this
# Optional: separate secret for refresh tokens (defaults to JWT_SECRET if not set)
JWT_REFRESH_SECRET=your_refresh_token_secret_here_change_this

# ---------------------------------------------------------------------------
# SAM.gov API
# ---------------------------------------------------------------------------
# Register at https://api.data.gov/signup/ (free)
# Then request access to the SAM.gov Opportunities API
SAM_API_KEY=your_sam_api_key_here

# ---------------------------------------------------------------------------
# Email (choose ONE option)
# ---------------------------------------------------------------------------
# Option A: Gmail (use an App Password, not your real password)
GMAIL_USER=youraddress@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# Option B: SendGrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Sender address shown in outgoing emails
EMAIL_FROM=noreply@govconscanner.com

# ---------------------------------------------------------------------------
# Datadog APM & Monitoring (optional)
# ---------------------------------------------------------------------------
# Opportunity Intelligence (Python FastAPI service – intelligence/)
# ---------------------------------------------------------------------------
# Path to the SQLite database used by the intelligence service.
# Defaults to "intelligence.db" in the working directory when not set.
SQLITE_DB_PATH=intelligence.db

# Port on which the FastAPI intelligence service listens (default: 8000)
INTELLIGENCE_PORT=8000

# How many days back to pull opportunities from SAM.gov on each refresh
INTELLIGENCE_DAYS_BACK=30

# Maximum number of opportunity records to fetch per refresh cycle
INTELLIGENCE_MAX_RECORDS=500

# ---------------------------------------------------------------------------
# Email (choose ONE option)
# ---------------------------------------------------------------------------
# Option A: Gmail (use an App Password, not your real password)
GMAIL_USER=youraddress@gmail.com
GMAIL_PASSWORD=<your-16-char-gmail-app-password-no-spaces>

# Option B: SendGrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Sender address shown in outgoing emails
EMAIL_FROM=noreply@govconscanner.com

# ---------------------------------------------------------------------------
# ERP Integrations (Infor SyteLine, Oracle ERP, SAP)
# ---------------------------------------------------------------------------
# 32-byte hex key for encrypting ERP client credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ERP_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# -- Infor SyteLine --
# INFOR_TENANT_URL=https://your-tenant.infor.com
# INFOR_TOKEN_URL=https://inforos.iam.inforcloudsuite.com/INFOROS_PRD/as/token.oauth2
# INFOR_CLIENT_ID=your_infor_client_id
# INFOR_CLIENT_SECRET=your_infor_client_secret
# INFOR_SCOPE=

# -- Oracle ERP Cloud --
# ORACLE_TENANT_URL=https://your-oracle-erp-instance.oraclecloud.com
# ORACLE_TOKEN_URL=https://idcs-xxxx.identity.oraclecloud.com/oauth2/v1/token
# ORACLE_CLIENT_ID=your_oracle_client_id
# ORACLE_CLIENT_SECRET=your_oracle_client_secret
# ORACLE_SCOPE=

# -- SAP S/4HANA / Cloud Platform --
# SAP_TENANT_URL=https://your-sap-system.s4hana.ondemand.com
# SAP_TOKEN_URL=https://your-subaccount.authentication.eu10.hana.ondemand.com/oauth/token
# SAP_CLIENT_ID=your_sap_client_id
# SAP_CLIENT_SECRET=your_sap_client_secret
# SAP_SCOPE=


# Payment link for the "Upgrade Now" button shown after the 30-day free trial.
# Replace with your live Stripe payment link before deploying to production.
STRIPE_PAYMENT_LINK=https://buy.stripe.com/aFa7sK8peh2l4Up8aVf7i02

# ---------------------------------------------------------------------------
# Application URL (used in password reset emails)
# ---------------------------------------------------------------------------
# Set to your production URL when deploying (e.g. https://app.govconscanner.com)
APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Email Digest Scheduler
# ---------------------------------------------------------------------------
# Cron expression controlling when the digest scheduler checks for users to email.
# Default runs at the top of every hour. Each user is emailed at the hour they
# configured in their email preferences (0–23).
# Format: "minute hour day month weekday"
DIGEST_CRON_SCHEDULE=0 * * * *
# Daily Email Digest Scheduler
# ---------------------------------------------------------------------------
# Cron expression controlling when the daily digest is sent (default: 7:00 AM daily).
# Standard 5-field cron syntax: minute hour day-of-month month day-of-week
DIGEST_CRON_SCHEDULE=0 7 * * *

# IANA timezone for the digest scheduler (default: America/New_York).
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones for valid values.
DIGEST_TIMEZONE=America/New_York

# ---------------------------------------------------------------------------
# Datadog APM & Monitoring (optional)
# ---------------------------------------------------------------------------
DD_ENABLED=false
DD_SERVICE=govcon-ai-scanner
DD_ENV=development
DD_VERSION=2.0.0
DD_SITE=datadoghq.com
DD_TRACE_AGENT_HOSTNAME=localhost
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125
DD_PROFILING_ENABLED=false
DD_TRACE_LOG_LEVEL=error
