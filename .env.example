# GovCon AI Scanner – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to source control.

# Required: Your SAM.gov API key
# Register at https://api.data.gov/signup/ (free)
# After registering, request access to the SAM.gov Opportunities API
SAM_API_KEY=your_sam_api_key_here

# Optional: Server port (defaults to 3000)
PORT=3000
